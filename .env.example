# SUPERVISOR_LLM_VENDOR=aliyun
# SUPERVISOR_LLM_MODEL=qwen-plus
# SUPERVISOR_LLM_API_KEY=sk-xxxxxxxxxxxx

# Insurance Consultant Agent Config (e.g. use a stronger model)
# INSURANCE_LLM_VENDOR=aliyun
# INSURANCE_LLM_MODEL=qwen-max
# INSURANCE_LLM_API_KEY=sk-xxxxxxxxxxxx

# Doc Processor Agent Config (e.g. use OpenAI for better reasoning on docs)
# DOC_LLM_VENDOR=openai
